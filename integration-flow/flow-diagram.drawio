<mxfile host="app.diagrams.net">
  <diagram name="Arquitetura de Integração LYNK" id="lynk-integration-architecture">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Arquitetura de Integração do LYNK" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontStyle=1;fontColor=#111827" vertex="1" parent="1">
          <mxGeometry x="560" y="40" width="520" height="50" as="geometry" />
        </mxCell>

        <mxCell id="subtitle" value="Frontend React + Backend Node.js + Banco SQL + Pipeline Smartconnector" style="text;html=1;strokeColor=none;fillColor=none;fontSize=15;fontColor=#4B5563" vertex="1" parent="1">
          <mxGeometry x="545" y="90" width="560" height="30" as="geometry" />
        </mxCell>

        <!-- Camadas principais -->
        <mxCell id="frontend" value="Frontend React&#xa;Landing page, marketplace, carrinho e tela de arquitetura" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="170" width="260" height="90" as="geometry" />
        </mxCell>

        <mxCell id="backend" value="Backend Node.js&#xa;API REST mockada com Express" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="390" y="170" width="260" height="90" as="geometry" />
        </mxCell>

        <mxCell id="data" value="Banco e SQL&#xa;Schema relacional + queries com JOINs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="700" y="170" width="260" height="90" as="geometry" />
        </mxCell>

        <mxCell id="pipeline" value="Pipeline de Integração&#xa;Filtro, validação, mapper, estoque, log e envio" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1010" y="170" width="300" height="90" as="geometry" />
        </mxCell>

        <!-- Modelo de dados -->
        <mxCell id="model-title" value="Modelo de Dados" style="text;html=1;strokeColor=none;fillColor=none;fontSize=20;fontStyle=1;fontColor=#111827" vertex="1" parent="1">
          <mxGeometry x="80" y="330" width="220" height="30" as="geometry" />
        </mxCell>

        <mxCell id="clientes" value="clientes&#xa;id, nome, email, cidade, estado" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#9CA3AF;fontSize=13" vertex="1" parent="1">
          <mxGeometry x="80" y="380" width="230" height="75" as="geometry" />
        </mxCell>

        <mxCell id="pedidos" value="pedidos&#xa;id, cliente_id, status, subtotal, total, data_entrega" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#9CA3AF;fontSize=13" vertex="1" parent="1">
          <mxGeometry x="360" y="380" width="260" height="75" as="geometry" />
        </mxCell>

        <mxCell id="itens" value="itens_pedido&#xa;id, pedido_id, produto_id, quantidade, preco_unitario" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#9CA3AF;fontSize=13" vertex="1" parent="1">
          <mxGeometry x="670" y="380" width="290" height="75" as="geometry" />
        </mxCell>

        <mxCell id="produtos" value="produtos&#xa;id, nome, categoria, preco, sku" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#9CA3AF;fontSize=13" vertex="1" parent="1">
          <mxGeometry x="1010" y="380" width="250" height="75" as="geometry" />
        </mxCell>

        <mxCell id="rel-clientes-pedidos" value="1:N" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=12" edge="1" parent="1" source="clientes" target="pedidos">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="rel-pedidos-itens" value="1:N" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=12" edge="1" parent="1" source="pedidos" target="itens">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="rel-produtos-itens" value="N:1" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=12" edge="1" parent="1" source="itens" target="produtos">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Query SQL -->
        <mxCell id="sql-title" value="Consulta SQL Principal" style="text;html=1;strokeColor=none;fillColor=none;fontSize=20;fontStyle=1;fontColor=#111827" vertex="1" parent="1">
          <mxGeometry x="80" y="530" width="260" height="30" as="geometry" />
        </mxCell>

        <mxCell id="sql-block" value="SELECT pedidos confirmados&#xa;+ cliente&#xa;+ itens do pedido&#xa;+ produtos&#xa;+ total_item&#xa;&#xa;WHERE p.status = 'confirmado'" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111827;strokeColor=#374151;fontSize=13;fontColor=#F9FAFB;align=left;spacingLeft=18" vertex="1" parent="1">
          <mxGeometry x="80" y="580" width="300" height="180" as="geometry" />
        </mxCell>

        <!-- Pipeline visual -->
        <mxCell id="pipeline-title" value="Pipeline Smartconnector" style="text;html=1;strokeColor=none;fillColor=none;fontSize=20;fontStyle=1;fontColor=#111827" vertex="1" parent="1">
          <mxGeometry x="460" y="530" width="300" height="30" as="geometry" />
        </mxCell>

        <mxCell id="node-db" value="1. Entrada SQL&#xa;dados relacionais" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="460" y="590" width="190" height="75" as="geometry" />
        </mxCell>

        <mxCell id="node-filter" value="2. Filtro&#xa;status confirmado" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF9C3;strokeColor=#CA8A04;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="710" y="590" width="190" height="75" as="geometry" />
        </mxCell>

        <mxCell id="node-validation" value="3. Validação&#xa;cliente, item, produto e valores" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="960" y="590" width="220" height="75" as="geometry" />
        </mxCell>

        <mxCell id="node-mapper" value="4. Mapper&#xa;linhas SQL para JSON" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1240" y="590" width="220" height="75" as="geometry" />
        </mxCell>

        <mxCell id="node-stock" value="5. Enriquecimento&#xa;GET /estoque/:produto_id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1240" y="740" width="220" height="75" as="geometry" />
        </mxCell>

        <mxCell id="node-log" value="6. Log&#xa;sucesso, bloqueios e erros" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="960" y="740" width="220" height="75" as="geometry" />
        </mxCell>

        <mxCell id="node-api" value="7. API Out&#xa;POST /pedidos" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="710" y="740" width="190" height="75" as="geometry" />
        </mxCell>

        <mxCell id="node-error" value="Erro de validação&#xa;bloqueia envio e registra log" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#6B7280;fontSize=12;dashed=1" vertex="1" parent="1">
          <mxGeometry x="960" y="900" width="220" height="75" as="geometry" />
        </mxCell>

        <!-- Payload -->
        <mxCell id="payload-title" value="Payload Final" style="text;html=1;strokeColor=none;fillColor=none;fontSize=20;fontStyle=1;fontColor=#111827" vertex="1" parent="1">
          <mxGeometry x="80" y="820" width="200" height="30" as="geometry" />
        </mxCell>

        <mxCell id="payload" value="{&#xa;  cliente_id: 101,&#xa;  itens: [&#xa;    { produto_id: 1, quantidade: 1 },&#xa;    { produto_id: 2, quantidade: 1 }&#xa;  ],&#xa;  data_entrega: '2026-06-10'&#xa;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111827;strokeColor=#374151;fontSize=13;fontColor=#F9FAFB;align=left;spacingLeft=18" vertex="1" parent="1">
          <mxGeometry x="80" y="870" width="360" height="180" as="geometry" />
        </mxCell>

        <!-- Conexões principais -->
        <mxCell id="edge-frontend-backend" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#4B5563" edge="1" parent="1" source="frontend" target="backend">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="edge-backend-data" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#4B5563" edge="1" parent="1" source="backend" target="data">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="edge-data-pipeline" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#4B5563" edge="1" parent="1" source="data" target="pipeline">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="edge-model-sql" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#2563EB" edge="1" parent="1" source="itens" target="sql-block">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="edge-sql-entry" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#2563EB" edge="1" parent="1" source="sql-block" target="node-db">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="edge-db-filter" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#4B5563" edge="1" parent="1" source="node-db" target="node-filter">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="edge-filter-validation" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#4B5563" edge="1" parent="1" source="node-filter" target="node-validation">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="edge-validation-mapper" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#4B5563" edge="1" parent="1" source="node-validation" target="node-mapper">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="edge-mapper-stock" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#4B5563" edge="1" parent="1" source="node-mapper" target="node-stock">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="edge-stock-log" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#4B5563" edge="1" parent="1" source="node-stock" target="node-log">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="edge-log-api" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#4B5563" edge="1" parent="1" source="node-log" target="node-api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="edge-api-payload" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#059669" edge="1" parent="1" source="node-api" target="payload">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="edge-validation-error" value="falha" style="endArrow=block;html=1;rounded=0;dashed=1;strokeColor=#DC2626;fontSize=12" edge="1" parent="1" source="node-validation" target="node-error">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="edge-stock-error" value="sem estoque" style="endArrow=block;html=1;rounded=0;dashed=1;strokeColor=#DC2626;fontSize=12" edge="1" parent="1" source="node-stock" target="node-error">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="edge-error-log" value="registra" style="endArrow=block;html=1;rounded=0;dashed=1;strokeColor=#DC2626;fontSize=12" edge="1" parent="1" source="node-error" target="node-log">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>