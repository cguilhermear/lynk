        <mxCell id="legend-validation" value="Validações / IF" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=12;fontStyle=1;fontColor=#78350F" vertex="1" parent="1">
          <mxGeometry x="270" y="130" width="170" height="34" as="geometry" />
        </mxCell>
        <mxCell id="legend-data" value="Banco / SQL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF5;strokeColor=#059669;fontSize=12;fontStyle=1;fontColor=#064E3B" vertex="1" parent="1">
          <mxGeometry x="460" y="130" width="170" height="34" as="geometry" />
