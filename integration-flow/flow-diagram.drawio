        <mxCell id="edge-5-6" value="pedido completo" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#059669;fontSize=11" edge="1" parent="1" source="n5-sql" target="n6-confirmed">
          <mxGeometry relative="1" as="geometry" />
