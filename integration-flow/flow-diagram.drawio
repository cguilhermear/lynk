        <mxCell id="edge-7-8" value="resultado da validação" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#4B5563;fontSize=11" edge="1" parent="1" source="n7-business-validation" target="n8-valid">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Main edges row 2 snake -->
        <mxCell id="edge-8-9" value="sim" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#16A34A;fontSize=11" edge="1" parent="1" source="n8-valid" target="n9-mapper">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-9-10" value="itens agregados" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#7C3AED;fontSize=11" edge="1" parent="1" source="n9-mapper" target="n10-split">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-10-11" value="para cada item" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#7C3AED;fontSize=11" edge="1" parent="1" source="n10-split" target="n11-stock">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-11-12" value="saldo retornado" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#16A34A;fontSize=11" edge="1" parent="1" source="n11-stock" target="n12-stock-if">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-12-13" value="sim" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#16A34A;fontSize=11" edge="1" parent="1" source="n12-stock-if" target="n13-build-payload">
          <mxGeometry relative="1" as="geometry" />
