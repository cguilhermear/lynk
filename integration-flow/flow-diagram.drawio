        <mxCell id="edge-13-14" value="payload pronto" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#7C3AED;fontSize=11" edge="1" parent="1" source="n13-build-payload" target="n14-idempotency">
