        <mxCell id="edge-18-19" value="log salvo" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#2563EB;fontSize=11" edge="1" parent="1" source="n18-success-log" target="n19-response">
          <mxGeometry relative="1" as="geometry" />
