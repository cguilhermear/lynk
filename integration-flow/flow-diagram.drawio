        <mxCell id="legend-transform" value="Transformação" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=12;fontStyle=1;fontColor=#3B0764" vertex="1" parent="1">
          <mxGeometry x="650" y="130" width="170" height="34" as="geometry" />
        </mxCell>
        <mxCell id="legend-api" value="API / Saída" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=12;fontStyle=1;fontColor=#14532D" vertex="1" parent="1">
          <mxGeometry x="840" y="130" width="170" height="34" as="geometry" />
        </mxCell>
        <mxCell id="legend-error" value="Erro / Bloqueio / Log" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=12;fontStyle=1;fontColor=#7F1D1D" vertex="1" parent="1">
          <mxGeometry x="1030" y="130" width="190" height="34" as="geometry" />
        </mxCell>

        <!-- Main flow row 1 -->
        <mxCell id="n1-webhook" value="1. Webhook Trigger&#xa;POST /webhook/pedido-confirmado&#xa;&#xa;Recebe evento externo:&#xa;pedido_id, status, origem, timestamp" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=13;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="80" y="220" width="210" height="110" as="geometry" />
        </mxCell>

        <mxCell id="n2-normalize" value="2. Set / Normalize&#xa;Padroniza entrada&#xa;&#xa;Gera correlation_id&#xa;normaliza status&#xa;remove campos inválidos" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#6B7280;fontSize=13;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="340" y="220" width="210" height="110" as="geometry" />
        </mxCell>

        <mxCell id="n3-auth" value="3. IF Segurança&#xa;Token / API Key válido?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=13;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="600" y="210" width="180" height="130" as="geometry" />
        </mxCell>

        <mxCell id="n4-payload" value="4. IF Payload&#xa;Campos mínimos OK?&#xa;&#xa;pedido_id&#xa;status&#xa;origem" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=13;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="840" y="210" width="180" height="130" as="geometry" />
        </mxCell>

        <mxCell id="n5-sql" value="5. SQL Query&#xa;Busca pedido completo&#xa;&#xa;pedidos + clientes&#xa;+ itens_pedido + produtos&#xa;&#xa;JOINs + total_item" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF5;strokeColor=#059669;fontSize=13;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="1080" y="220" width="230" height="110" as="geometry" />
        </mxCell>

        <mxCell id="n6-confirmed" value="6. IF Status&#xa;Pedido confirmado?&#xa;&#xa;p.status = 'confirmado'" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=13;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="1370" y="210" width="190" height="130" as="geometry" />
        </mxCell>

        <mxCell id="n7-business-validation" value="7. Code Validation&#xa;Valida regra de negócio&#xa;&#xa;cliente existe&#xa;email válido&#xa;itens &gt; 0&#xa;produto existe&#xa;valores coerentes&#xa;data_entrega válida" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;fontSize=13;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="1620" y="205" width="230" height="140" as="geometry" />
        </mxCell>

        <mxCell id="n8-valid" value="8. IF Dados&#xa;Tudo consistente?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=13;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="1920" y="210" width="180" height="130" as="geometry" />
        </mxCell>

        <!-- Main flow row 2 -->
        <mxCell id="n9-mapper" value="9. Mapper / Aggregate&#xa;Linhas SQL → JSON único&#xa;&#xa;cliente{}&#xa;itens[]&#xa;subtotal, imposto, total&#xa;data_entrega" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=13;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="1880" y="430" width="230" height="130" as="geometry" />
        </mxCell>

        <mxCell id="n10-split" value="10. Split In Batches&#xa;Percorre itens do pedido&#xa;&#xa;1 produto por vez&#xa;mantém pedido agrupado" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=13;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="1600" y="440" width="220" height="110" as="geometry" />
        </mxCell>

        <mxCell id="n11-stock" value="11. HTTP Request&#xa;GET /estoque/{produto_id}&#xa;&#xa;Consulta estoque no backend Node.js / API mockada" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=13;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="1320" y="440" width="230" height="110" as="geometry" />
        </mxCell>

        <mxCell id="n12-stock-if" value="12. IF Estoque&#xa;disponível &gt;= quantidade?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=13;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="1080" y="430" width="190" height="130" as="geometry" />
        </mxCell>

        <mxCell id="n13-build-payload" value="13. Build Payload&#xa;Monta body final&#xa;&#xa;cliente_id&#xa;itens: produto_id, quantidade, preco_unitario&#xa;data_entrega&#xa;total" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=13;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="790" y="425" width="230" height="140" as="geometry" />
        </mxCell>

        <mxCell id="n14-idempotency" value="14. IF Idempotência&#xa;Pedido já integrado?&#xa;&#xa;Evita duplicidade no POST /pedidos" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=13;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="550" y="430" width="190" height="130" as="geometry" />
        </mxCell>

        <mxCell id="n15-post" value="15. HTTP Request&#xa;POST /pedidos&#xa;&#xa;Envia pedido transformado para API de destino" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=13;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="300" y="440" width="210" height="110" as="geometry" />
        </mxCell>

        <mxCell id="n16-post-if" value="16. IF Resposta API&#xa;201 / 200 recebido?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=13;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="70" y="430" width="180" height="130" as="geometry" />
        </mxCell>

        <!-- Main flow row 3 -->
        <mxCell id="n17-patch" value="17. PATCH /pedidos/{id}&#xa;Atualiza status de integração&#xa;&#xa;integrado / processado&#xa;salva external_order_id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=13;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="300" y="650" width="230" height="110" as="geometry" />
        </mxCell>

        <mxCell id="n18-success-log" value="18. Log Sucesso&#xa;Registra rastreabilidade&#xa;&#xa;correlation_id&#xa;pedido_id&#xa;payload enviado&#xa;status API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;fontSize=13;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="580" y="650" width="230" height="110" as="geometry" />
        </mxCell>

        <mxCell id="n19-response" value="19. Webhook Response&#xa;200 OK&#xa;&#xa;Fluxo concluído&#xa;pedido integrado com sucesso" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=13;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="860" y="650" width="230" height="110" as="geometry" />
        </mxCell>

        <!-- Error and alternative branches -->
        <mxCell id="e1-auth" value="Erro 401&#xa;Bloqueia fluxo&#xa;&#xa;Token ausente ou inválido" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=12;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="600" y="820" width="210" height="90" as="geometry" />
        </mxCell>

        <mxCell id="e2-payload" value="Erro 400&#xa;Payload inválido&#xa;&#xa;pedido_id/status/origem ausente" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=12;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="840" y="820" width="210" height="90" as="geometry" />
        </mxCell>

        <mxCell id="e3-not-confirmed" value="Skip 204&#xa;Pedido ignorado&#xa;&#xa;Status diferente de confirmado&#xa;não envia para API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#6B7280;fontSize=12;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="1320" y="820" width="230" height="90" as="geometry" />
        </mxCell>

        <mxCell id="e4-business" value="Erro 422&#xa;Regra de negócio falhou&#xa;&#xa;cliente/item/produto/valor/data inválido" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=12;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="1640" y="820" width="230" height="90" as="geometry" />
        </mxCell>

        <mxCell id="e5-stock" value="Erro 409&#xa;Estoque insuficiente&#xa;&#xa;Bloqueia envio do pedido&#xa;mantém rastreabilidade" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=12;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="1080" y="820" width="220" height="90" as="geometry" />
        </mxCell>

        <mxCell id="e6-duplicate" value="Duplicidade detectada&#xa;Não faz novo POST&#xa;&#xa;Retorna pedido já processado" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#6B7280;fontSize=12;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="360" y="820" width="210" height="90" as="geometry" />
        </mxCell>

        <mxCell id="e7-retry" value="Retry HTTP&#xa;Tenta novamente até 3x&#xa;&#xa;Falha temporária na API&#xa;timeout / 5xx" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=12;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="80" y="820" width="220" height="90" as="geometry" />
        </mxCell>

        <mxCell id="e8-api-final" value="Erro Final API&#xa;Registra falha após retry&#xa;&#xa;Retorna 502/500&#xa;não atualiza como integrado" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=12;fontStyle=1;spacing=8" vertex="1" parent="1">
          <mxGeometry x="80" y="960" width="220" height="90" as="geometry" />
        </mxCell>

        <mxCell id="e9-error-log" value="Log Técnico Central&#xa;Todos os bloqueios e erros&#xa;&#xa;correlation_id&#xa;etapa do erro&#xa;motivo&#xa;payload original&#xa;payload transformado quando existir" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111827;strokeColor=#374151;fontSize=12;fontStyle=1;fontColor=#F9FAFB;spacing=8" vertex="1" parent="1">
          <mxGeometry x="600" y="970" width="340" height="130" as="geometry" />
        </mxCell>

        <!-- SQL and payload documentation blocks -->
        <mxCell id="doc-sql-title" value="Consulta SQL oficial do fluxo" style="text;html=1;strokeColor=none;fillColor=none;fontSize=20;fontStyle=1;fontColor=#111827" vertex="1" parent="1">
          <mxGeometry x="80" y="1140" width="360" height="30" as="geometry" />
        </mxCell>

        <mxCell id="doc-sql" value="SELECT&#xa;  p.id AS pedido_id, p.status, p.subtotal, p.imposto, p.total, p.data_entrega,&#xa;  c.id AS cliente_id, c.nome, c.email, c.cidade, c.estado,&#xa;  i.produto_id, i.quantidade, i.preco_unitario,&#xa;  pr.nome AS produto_nome, pr.sku, pr.categoria,&#xa;  (i.quantidade * i.preco_unitario) AS total_item&#xa;FROM pedidos p&#xa;JOIN clientes c ON c.id = p.cliente_id&#xa;JOIN itens_pedido i ON i.pedido_id = p.id&#xa;JOIN produtos pr ON pr.id = i.produto_id&#xa;WHERE p.id = :pedido_id&#xa;  AND p.status = 'confirmado';" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111827;strokeColor=#374151;fontSize=12;fontColor=#F9FAFB;align=left;spacingLeft=16;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="80" y="1180" width="720" height="230" as="geometry" />
        </mxCell>

        <mxCell id="doc-payload-title" value="Payload enviado no POST /pedidos" style="text;html=1;strokeColor=none;fillColor=none;fontSize=20;fontStyle=1;fontColor=#111827" vertex="1" parent="1">
          <mxGeometry x="880" y="1140" width="360" height="30" as="geometry" />
        </mxCell>

        <mxCell id="doc-payload" value="{&#xa;  &quot;cliente_id&quot;: 101,&#xa;  &quot;origem&quot;: &quot;LYNK_SMARTCONNECTOR&quot;,&#xa;  &quot;correlation_id&quot;: &quot;evt_20260529_0001&quot;,&#xa;  &quot;itens&quot;: [&#xa;    { &quot;produto_id&quot;: 1, &quot;quantidade&quot;: 2, &quot;preco_unitario&quot;: 49.90 },&#xa;    { &quot;produto_id&quot;: 2, &quot;quantidade&quot;: 1, &quot;preco_unitario&quot;: 89.90 }&#xa;  ],&#xa;  &quot;subtotal&quot;: 189.70,&#xa;  &quot;imposto&quot;: 18.97,&#xa;  &quot;total&quot;: 208.67,&#xa;  &quot;data_entrega&quot;: &quot;2026-06-10&quot;&#xa;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111827;strokeColor=#374151;fontSize=12;fontColor=#F9FAFB;align=left;spacingLeft=16;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="880" y="1180" width="620" height="230" as="geometry" />
        </mxCell>

        <mxCell id="doc-endpoints-title" value="Endpoints usados" style="text;html=1;strokeColor=none;fillColor=none;fontSize=20;fontStyle=1;fontColor=#111827" vertex="1" parent="1">
          <mxGeometry x="1570" y="1140" width="260" height="30" as="geometry" />
        </mxCell>

        <mxCell id="doc-endpoints" value="Entrada conceitual do fluxo:&#xa;POST /webhook/pedido-confirmado&#xa;&#xa;API mockada/documentada:&#xa;GET /produtos&#xa;GET /estoque/{produto_id}&#xa;POST /pedidos&#xa;GET /pedidos/{pedido_id}&#xa;PATCH /pedidos/{pedido_id}&#xa;&#xa;Tabelas oficiais:&#xa;produtos, clientes, pedidos, itens_pedido" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#9CA3AF;fontSize=12;align=left;spacingLeft=16;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="1570" y="1180" width="470" height="230" as="geometry" />
        </mxCell>

        <!-- Main edges row 1 -->
        <mxCell id="edge-1-2" value="evento recebido" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#4B5563;fontSize=11" edge="1" parent="1" source="n1-webhook" target="n2-normalize">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-2-3" value="entrada normalizada" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#4B5563;fontSize=11" edge="1" parent="1" source="n2-normalize" target="n3-auth">
          <mxGeometry relative="1" as="geometry" />
