        <mxCell id="smart-db" value="Banco SQL documentado&#xa;&#xa;produtos&#xa;clientes&#xa;pedidos&#xa;itens_pedido" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="90" y="990" width="180" height="120" as="geometry" />
        </mxCell>

        <mxCell id="smart-query" value="SQL Query com JOINs&#xa;&#xa;pedidos + clientes&#xa;+ itens_pedido + produtos&#xa;&#xa;WHERE p.status = 'confirmado'" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="320" y="980" width="220" height="140" as="geometry" />
        </mxCell>

        <mxCell id="smart-filter" value="Filtro&#xa;Pedido confirmado?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="590" y="985" width="150" height="130" as="geometry" />
        </mxCell>

        <mxCell id="smart-validation" value="Validação de dados&#xa;&#xa;cliente existe&#xa;pedido tem itens&#xa;produto existe&#xa;quantidade &gt; 0&#xa;preço &gt; 0&#xa;subtotal confere&#xa;data_entrega válida" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="790" y="955" width="210" height="180" as="geometry" />
        </mxCell>

        <mxCell id="smart-map" value="Transformação / Mapper&#xa;&#xa;Linhas SQL viram JSON único&#xa;&#xa;cliente_id&#xa;itens[]&#xa;subtotal&#xa;imposto&#xa;total&#xa;data_entrega" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1050" y="955" width="210" height="180" as="geometry" />
        </mxCell>

        <mxCell id="smart-stock" value="Enriquecimento&#xa;GET /estoque/{produto_id}&#xa;&#xa;Valida disponibilidade antes do envio" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1310" y="980" width="220" height="130" as="geometry" />
        </mxCell>

        <mxCell id="smart-stock-if" value="Estoque suficiente?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1580" y="985" width="150" height="130" as="geometry" />
