        <!-- Success edges row 3 -->
        <mxCell id="edge-16-17" value="sim" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#16A34A;fontSize=11" edge="1" parent="1" source="n16-post-if" target="n17-patch">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-17-18" value="status atualizado" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#16A34A;fontSize=11" edge="1" parent="1" source="n17-patch" target="n18-success-log">
          <mxGeometry relative="1" as="geometry" />
