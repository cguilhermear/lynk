        <mxCell id="edge-4-5" value="sim" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#16A34A;fontSize=11" edge="1" parent="1" source="n4-payload" target="n5-sql">
          <mxGeometry relative="1" as="geometry" />
