        <mxCell id="smart-e7" value="sim" style="endArrow=block;html=1;rounded=0;dashed=1;strokeWidth=2;strokeColor=#16A34A;fontSize=11" edge="1" parent="1" source="smart-stock-if" target="smart-log">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="smart-e8" value="envio final" style="endArrow=block;html=1;rounded=0;dashed=1;strokeWidth=2;strokeColor=#7C3AED;fontSize=11" edge="1" parent="1" source="smart-log" target="smart-post">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Swimlane 4: Erros e validações -->
        <mxCell id="lane-errors" value="LANE 4 — CAMINHOS DE ERRO, VALIDAÇÕES E RESPOSTAS ESPERADAS" style="swimlane;html=1;startSize=32;rounded=1;fillColor=#FEF2F2;strokeColor=#DC2626;fontSize=15;fontStyle=1;fontColor=#7F1D1D" vertex="1" parent="1">
          <mxGeometry x="60" y="1300" width="2220" height="300" as="geometry" />
        </mxCell>

        <mxCell id="err-empty-items" value="Pedido sem itens&#xa;&#xa;Validação Smartconnector: bloqueia&#xa;Backend POST: retorna 400 se itens vazio" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#6B7280;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="90" y="1390" width="220" height="110" as="geometry" />
        </mxCell>

        <mxCell id="err-invalid-product" value="Produto inválido&#xa;&#xa;Smartconnector: bloqueia&#xa;Backend atual: não bloqueia produto inexistente, calcula preço 0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="350" y="1390" width="240" height="110" as="geometry" />
        </mxCell>

        <mxCell id="err-invalid-quantity" value="Quantidade inválida&#xa;&#xa;Smartconnector: bloqueia&#xa;Backend POST: bloqueia quantidade &lt;= 0 com 400" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#6B7280;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="630" y="1390" width="230" height="110" as="geometry" />
        </mxCell>

        <mxCell id="err-subtotal" value="Subtotal divergente&#xa;&#xa;Query documentada confere diferença por HAVING ABS(...) &gt; 0.01&#xa;Backend atual recalcula, mas não compara com base SQL real" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#6B7280;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="900" y="1380" width="260" height="130" as="geometry" />
        </mxCell>

        <mxCell id="err-stock" value="Estoque não encontrado / insuficiente&#xa;&#xa;GET /estoque/:produto_id pode retornar 404&#xa;Smartconnector bloqueia envio&#xa;Backend POST atual não consulta estoque" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1200" y="1380" width="260" height="130" as="geometry" />
        </mxCell>

        <mxCell id="err-api-400" value="API 400&#xa;&#xa;POST /pedidos retorna erro para payload inválido: cliente_id, data_entrega ou itens ausentes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#6B7280;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1500" y="1390" width="230" height="110" as="geometry" />
        </mxCell>

        <mxCell id="err-api-404" value="API 404&#xa;&#xa;GET /pedidos/:id ou PATCH /pedidos/:id retorna 404 se pedido não existir&#xa;GET /estoque/:produto_id retorna 404 se não houver estoque" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#6B7280;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1770" y="1380" width="260" height="130" as="geometry" />
        </mxCell>

        <mxCell id="err-final-log" value="Log técnico esperado&#xa;&#xa;Registra etapa, motivo, payload original, payload transformado quando existir e resposta da API.&#xa;&#xa;Hoje isso está documentado, não persistido em banco real." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111827;strokeColor=#374151;fontSize=12;fontStyle=1;fontColor=#F9FAFB;align=left;spacingLeft=12" vertex="1" parent="1">
          <mxGeometry x="2070" y="1375" width="180" height="140" as="geometry" />
        </mxCell>

        <!-- Error edges -->
        <mxCell id="err-e1" value="falha" style="endArrow=block;html=1;rounded=0;dashed=1;strokeWidth=2;strokeColor=#DC2626;fontSize=11" edge="1" parent="1" source="smart-validation" target="err-empty-items">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="err-e2" value="falha" style="endArrow=block;html=1;rounded=0;dashed=1;strokeWidth=2;strokeColor=#DC2626;fontSize=11" edge="1" parent="1" source="smart-validation" target="err-invalid-product">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="err-e3" value="falha" style="endArrow=block;html=1;rounded=0;dashed=1;strokeWidth=2;strokeColor=#DC2626;fontSize=11" edge="1" parent="1" source="smart-validation" target="err-invalid-quantity">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="err-e4" value="falha" style="endArrow=block;html=1;rounded=0;dashed=1;strokeWidth=2;strokeColor=#DC2626;fontSize=11" edge="1" parent="1" source="smart-validation" target="err-subtotal">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="err-e5" value="não" style="endArrow=block;html=1;rounded=0;dashed=1;strokeWidth=2;strokeColor=#DC2626;fontSize=11" edge="1" parent="1" source="smart-stock-if" target="err-stock">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Seção inferior: payload e SQL -->
        <mxCell id="doc-sql-title" value="SQL principal documentado" style="text;html=1;strokeColor=none;fillColor=none;fontSize=20;fontStyle=1;fontColor=#111827" vertex="1" parent="1">
          <mxGeometry x="70" y="1630" width="360" height="30" as="geometry" />
        </mxCell>

        <mxCell id="doc-sql" value="SELECT&#xa;  p.id AS pedido_id,&#xa;  p.status,&#xa;  p.subtotal,&#xa;  p.imposto,&#xa;  p.total,&#xa;  p.data_entrega,&#xa;  c.id AS cliente_id,&#xa;  c.nome,&#xa;  c.email,&#xa;  c.cidade,&#xa;  c.estado,&#xa;  ip.produto_id,&#xa;  ip.quantidade,&#xa;  ip.preco_unitario,&#xa;  pr.nome AS produto_nome,&#xa;  pr.categoria,&#xa;  pr.sku,&#xa;  (ip.quantidade * ip.preco_unitario) AS total_item&#xa;FROM pedidos p&#xa;INNER JOIN clientes c ON c.id = p.cliente_id&#xa;INNER JOIN itens_pedido ip ON ip.pedido_id = p.id&#xa;INNER JOIN produtos pr ON pr.id = ip.produto_id&#xa;WHERE p.status = 'confirmado';" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111827;strokeColor=#374151;fontSize=12;fontColor=#F9FAFB;align=left;spacingLeft=14;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="70" y="1670" width="720" height="360" as="geometry" />
        </mxCell>

        <mxCell id="doc-payload-title" value="Payload final documentado para POST /pedidos" style="text;html=1;strokeColor=none;fillColor=none;fontSize=20;fontStyle=1;fontColor=#111827" vertex="1" parent="1">
          <mxGeometry x="850" y="1630" width="520" height="30" as="geometry" />
        </mxCell>

        <mxCell id="doc-payload" value="{&#xa;  &quot;cliente_id&quot;: 101,&#xa;  &quot;itens&quot;: [&#xa;    {&#xa;      &quot;produto_id&quot;: 1,&#xa;      &quot;quantidade&quot;: 2,&#xa;      &quot;preco_unitario&quot;: 49.90&#xa;    },&#xa;    {&#xa;      &quot;produto_id&quot;: 2,&#xa;      &quot;quantidade&quot;: 1,&#xa;      &quot;preco_unitario&quot;: 89.90&#xa;    }&#xa;  ],&#xa;  &quot;subtotal&quot;: 189.70,&#xa;  &quot;imposto&quot;: 18.97,&#xa;  &quot;total&quot;: 208.67,&#xa;  &quot;data_entrega&quot;: &quot;2026-06-10&quot;&#xa;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111827;strokeColor=#374151;fontSize=12;fontColor=#F9FAFB;align=left;spacingLeft=14;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="850" y="1670" width="560" height="360" as="geometry" />
        </mxCell>

        <mxCell id="doc-recruiter-title" value="O que o recrutador precisa enxergar" style="text;html=1;strokeColor=none;fillColor=none;fontSize=20;fontStyle=1;fontColor=#111827" vertex="1" parent="1">
          <mxGeometry x="1470" y="1630" width="520" height="30" as="geometry" />
        </mxCell>

        <mxCell id="doc-recruiter" value="1. Frontend React existe e funciona com marketplace, carrinho e Zustand.&#xa;&#xa;2. Backend Express existe e expõe endpoints REST mockados.&#xa;&#xa;3. A integração SQL exigida na avaliação está documentada com tabelas normalizadas, JOINs, validações e payload.&#xa;&#xa;4. O sistema separa claramente o que está implementado do que é simulação/documentação.&#xa;&#xa;5. O fluxo mostra validações, erros, endpoints, dados mockados e gaps técnicos reais.&#xa;&#xa;6. Próximo incremento natural: conectar GET /produtos no marketplace e POST /pedidos no carrinho." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#9CA3AF;fontSize=13;fontStyle=1;align=left;spacingLeft=14;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="1470" y="1670" width="760" height="360" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>