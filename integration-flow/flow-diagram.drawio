        <mxCell id="edge-3-4" value="sim" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#16A34A;fontSize=11" edge="1" parent="1" source="n3-auth" target="n4-payload">
          <mxGeometry relative="1" as="geometry" />
