        <mxCell id="smart-log" value="Log do fluxo&#xa;&#xa;pedido_id&#xa;etapa&#xa;payload original&#xa;payload transformado&#xa;sucesso ou erro" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1780" y="965" width="190" height="160" as="geometry" />
        </mxCell>

        <mxCell id="smart-post" value="POST /pedidos&#xa;&#xa;Envia payload final para API mockada documentada" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="2020" y="990" width="200" height="120" as="geometry" />
        </mxCell>

        <mxCell id="smart-note" value="IMPORTANTE&#xa;&#xa;Este fluxo é documentação/simulação do Smartconnector.&#xa;Ele demonstra a integração exigida na avaliação, mas não existe como runner executado automaticamente dentro do app hoje." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=13;fontStyle=1;fontColor=#7F1D1D;align=left;spacingLeft=12" vertex="1" parent="1">
