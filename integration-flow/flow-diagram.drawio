        <mxCell id="title" value="Fluxo Real de Integração do LYNK — Modelo Smartconnector / n8n" style="text;html=1;strokeColor=none;fillColor=none;fontSize=30;fontStyle=1;fontColor=#111827" vertex="1" parent="1">
          <mxGeometry x="470" y="35" width="1160" height="50" as="geometry" />
        </mxCell>

        <mxCell id="subtitle" value="Webhook de entrada → validações → SQL com JOINs → transformação → estoque → envio para API → atualização/logs/tratamento de erros" style="text;html=1;strokeColor=none;fillColor=none;fontSize=15;fontColor=#4B5563" vertex="1" parent="1">
