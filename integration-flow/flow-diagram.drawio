        <mxCell id="lane-smart" value="LANE 3 — FLUXO SMARTCONNECTOR DOCUMENTADO / SIMULADO PARA A AVALIAÇÃO" style="swimlane;html=1;startSize=32;rounded=1;fillColor=#F5F3FF;strokeColor=#7C3AED;fontSize=15;fontStyle=1;fontColor=#3B0764" vertex="1" parent="1">
