        <mxCell id="edge-6-7" value="sim" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#16A34A;fontSize=11" edge="1" parent="1" source="n6-confirmed" target="n7-business-validation">
          <mxGeometry relative="1" as="geometry" />
